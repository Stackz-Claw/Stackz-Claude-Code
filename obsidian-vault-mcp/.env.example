# Environment Configuration
# Copy this to .env and configure

# Vault path (Obsidian vault directory)
VAULT_PATH=~/.stackz/vault/

# Backup settings
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600000

# Cache settings (milliseconds)
CACHE_TTL=30000

# File size limits (bytes)
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=info
