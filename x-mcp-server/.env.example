# Environment Configuration
# Copy this file to .env and fill in your credentials

# Twitter API Credentials
X_BEARER_TOKEN=your_bearer_token_here

# Account 1 (Primary)
X_ACCOUNT_1_ACCESS_TOKEN=your_access_token
X_ACCOUNT_1_API_KEY=your_api_key
X_ACCOUNT_1_API_SECRET=your_api_secret

# Account 2 (Optional)
X_ACCOUNT_2_ACCESS_TOKEN=
X_ACCOUNT_2_API_KEY=
X_ACCOUNT_2_API_SECRET=

# Account 3 (Optional)
X_ACCOUNT_3_ACCESS_TOKEN=
X_ACCOUNT_3_API_KEY=
X_ACCOUNT_3_API_SECRET=

# Default Account
X_DEFAULT_ACCOUNT=1

# Server Configuration
PORT=3000
LOG_LEVEL=info
