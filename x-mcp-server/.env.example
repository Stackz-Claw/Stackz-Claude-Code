# Environment Configuration
# Copy this file to .env and fill in your credentials

# Twitter API Credentials (Bearer token for read-only operations)
X_BEARER_TOKEN=your_bearer_token_here

# Account 1 (Primary)
# OAuth 1.0a requires: access token + access secret
X_ACCOUNT_1_ACCESS_TOKEN=your_access_token_here
X_ACCOUNT_1_ACCESS_SECRET=your_access_secret_here
X_ACCOUNT_1_API_KEY=your_api_key_here
X_ACCOUNT_1_API_SECRET=your_api_secret_here

# Account 2 (Optional)
X_ACCOUNT_2_ACCESS_TOKEN=
X_ACCOUNT_2_ACCESS_SECRET=
X_ACCOUNT_2_API_KEY=
X_ACCOUNT_2_API_SECRET=

# Account 3 (Optional)
X_ACCOUNT_3_ACCESS_TOKEN=
X_ACCOUNT_3_ACCESS_SECRET=
X_ACCOUNT_3_API_KEY=
X_ACCOUNT_3_API_SECRET=

# Default Account
X_DEFAULT_ACCOUNT=1

# Server Configuration
PORT=3000
LOG_LEVEL=info