{
  "name": "x-mcp-server",
  "version": "1.0.0",
  "description": "Multi-account Twitter/X MCP server for STACKZ agent swarm",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:debug": "ts-node --inspect src/index.ts",
    "test": "jest",
    "test:post": "ts-node src/scripts/test-post.ts",
    "test:search": "ts-node src/scripts/test-search.ts",
    "test:timeline": "ts-node src/scripts/test-timeline.ts",
    "logs": "tail -f logs/server.log"
  },
  "keywords": ["mcp", "twitter", "x", "agent", "stackz"],
  "author": "STACKZ",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "twitter-api-v2": "^1.16.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "winston": "^3.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11"
  }
}
