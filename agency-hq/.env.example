# ─────────────────────────────────────────
# THE AGENCY HQ — Environment Variables
# ─────────────────────────────────────────

# Backend server port
PORT=3001

# ─── TELEGRAM BOTS ───────────────────────
# Step 1: Message @BotFather on Telegram
# Step 2: /newbot → follow prompts → get token
# Create TWO bots: one for Smoke, one for Stackz

SMOKE_BOT_TOKEN=your_smoke_bot_token_here
STACKZ_BOT_TOKEN=your_stackz_bot_token_here

# Your Telegram Chat ID (to receive messages)
# Get it: message @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── FRONTEND ────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
